
# =========================================================
# DocuPilot Environment Variables
# Copy this file to .env.local and fill in your own keys.
#
#   PowerShell:  Copy-Item .env.example .env.local
#   macOS/Linux: cp .env.example .env.local
#
# NEVER commit .env.local — it is listed in .gitignore.
# NEVER use SUPABASE_SERVICE_ROLE_KEY as a NEXT_PUBLIC_ variable.
# =========================================================


# ---------------------------------------------------------
# Gemini AI  (REQUIRED for all AI features)
# Get your key at: https://aistudio.google.com/apikey
# Used by: SRS Generator, Contract-to-Actions, Scope Guard
# ---------------------------------------------------------

GEMINI_API_KEY=

# Optional: override the primary model (default: gemini-2.5-flash-lite)
# GEMINI_FAST_MODEL=gemini-2.5-flash-lite

# Optional: override the fallback model used when the primary is unavailable (default: gemini-2.0-flash)
# Recommended fallback: gemini-2.5-flash (stronger) or gemini-2.0-flash (more available)
# GEMINI_FALLBACK_MODEL=gemini-2.5-flash


# ---------------------------------------------------------
# Qwen AI  (OPTIONAL — tertiary fallback if Gemini is unavailable)
# Used when Gemini fails with 503/502/504/429 or auth errors.
# Get your key at: https://dashscope-intl.aliyuncs.com
# Leave QWEN_API_KEY blank to disable Qwen and go straight to local fallback.
# ---------------------------------------------------------

QWEN_API_KEY=

# Qwen OpenAI-compatible base URL (default shown; override only if using a custom endpoint)
# QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Qwen model ID (default: qwen-plus)
# QWEN_MODEL=qwen-plus


# ---------------------------------------------------------
# Supabase Database  (REQUIRED for persistence)
# Server-side only. Do NOT prefix with NEXT_PUBLIC_ for secrets.
# Get these from your Supabase project → Settings → API.
# ---------------------------------------------------------

# The public project URL (safe to expose — used as NEXT_PUBLIC for client SDK too)
NEXT_PUBLIC_SUPABASE_URL=

# Service role key — server-side only, gives full DB access
# NEVER use this as a NEXT_PUBLIC_ variable
SUPABASE_SERVICE_ROLE_KEY=


# ---------------------------------------------------------
# Optional: Supabase anon key (for future client-side SDK use)
# Only needed if the frontend directly queries Supabase.
# ---------------------------------------------------------

# NEXT_PUBLIC_SUPABASE_ANON_KEY=
